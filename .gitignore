# ASCIIP .gitignore

# --- Environment ---
.env
.env.local
.env.*.local
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# --- Node / Next ---
node_modules/
.next/
.turbo/
out/
dist/
build/
*.tsbuildinfo
.pnpm-store/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Editors / OS ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
.DS_Store
Thumbs.db
desktop.ini

# --- ASCIIP data ---
# Keep the committed snapshots; ignore derived and runtime-generated data.
data/raw/**
!data/raw/.gitkeep
data/features/**
!data/features/.gitkeep
data/models/**
!data/models/.gitkeep
data/exports/**
!data/exports/.gitkeep

# Geocode cache is snapshot-adjacent; committed when present.
!data/snapshots/**

# --- Playwright / test artifacts ---
playwright-report/
test-results/

# --- Build metadata ---
*.log
*.pid
.lock
uv.lock
