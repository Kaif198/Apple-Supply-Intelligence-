# =============================================================================
# ASCIIP — Environment configuration
# =============================================================================
# Copy this file to `.env` and fill in the values you want. NONE of the keys
# below are required for first boot: the system ships with calibrated Parquet
# snapshots and will run fully offline when keys are missing. Adding a key
# upgrades that source from snapshot-fallback to live ingestion.
#
# All services used here are free-tier. No paid subscriptions, credit cards,
# or time-limited trials are required.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime basics
# -----------------------------------------------------------------------------

# Deployment environment: "development" | "staging" | "production"
ASCIIP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
ASCIIP_LOG_LEVEL=INFO

# When true, emits human-formatted logs via `rich`. Production ships JSON.
ASCIIP_LOG_PRETTY=true

# Comma-separated list of origins the API will accept. No wildcards in prod.
ASCIIP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Where the frontend finds the API. Used both client- and server-side in Next.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Data paths (override only when running in containers with mounted volumes)
# -----------------------------------------------------------------------------

ASCIIP_DATA_DIR=./data
ASCIIP_DUCKDB_PATH=./data/features/asciip.duckdb
ASCIIP_SNAPSHOTS_DIR=./data/snapshots
ASCIIP_MODELS_DIR=./data/models
ASCIIP_EXPORTS_DIR=./data/exports

# -----------------------------------------------------------------------------
# External data sources (all optional; snapshots used when absent)
# -----------------------------------------------------------------------------

# FRED — Federal Reserve Economic Data. Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Marketaux — free news API. Free key: https://www.marketaux.com/
MARKETAUX_API_KEY=

# Finnhub — free company fundamentals + news. Free key: https://finnhub.io/
FINNHUB_API_KEY=

# UN Comtrade — anonymous works (100/hr); with a free key 10,000/day. Register: https://comtradeplus.un.org/
COMTRADE_API_KEY=

# OpenStreetMap Nominatim requires a descriptive User-Agent; never lie.
ASCIIP_NOMINATIM_USER_AGENT="asciip/0.1 (ops@example.com)"

# Apple Supplier Responsibility PDF URL (Apple changes the path yearly).
# Leave blank to let the extractor walk the SR page index for the current year.
APPLE_SUPPLIER_PDF_URL=

# -----------------------------------------------------------------------------
# Outbound alert channels (optional; alerts still land in DB + UI without these)
# -----------------------------------------------------------------------------

# SMTP for email alerts. Leave any value blank to disable email alerts.
ASCIIP_SMTP_HOST=
ASCIIP_SMTP_PORT=587
ASCIIP_SMTP_USERNAME=
ASCIIP_SMTP_PASSWORD=
ASCIIP_SMTP_FROM=asciip@example.com
ASCIIP_SMTP_TO=

# Webhook URL for alert POSTs (Slack, PagerDuty, Teams, any HTTPS endpoint).
ASCIIP_ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Model + simulation tuning (sensible defaults; override only when experimenting)
# -----------------------------------------------------------------------------

# DCF assumptions. WACC calibrated to AAPL Q4-FY25 implied cost of capital.
ASCIIP_DCF_WACC=0.086
ASCIIP_DCF_TERMINAL_GROWTH=0.025
ASCIIP_DCF_TAX_RATE=0.16
ASCIIP_DCF_HORIZON_YEARS=5

# Monte Carlo
ASCIIP_MC_ITERATIONS=10000
ASCIIP_MC_SEED=20260101

# ML hyperparameters (comma-separated key=value pairs, or leave blank for defaults)
ASCIIP_XGB_PARAMS=
ASCIIP_PROPHET_SEASONALITY_STRENGTH=10
ASCIIP_RIDGE_ALPHA_MAX=100

# Data-refresh intervals (seconds)
ASCIIP_REFRESH_COMMODITY_SECONDS=3600
ASCIIP_REFRESH_TRADE_SECONDS=21600
ASCIIP_REFRESH_SUPPLIER_SECONDS=7776000

# -----------------------------------------------------------------------------
# Security / rate limiting
# -----------------------------------------------------------------------------

ASCIIP_RATE_LIMIT_DEFAULT=100/minute
ASCIIP_RATE_LIMIT_SCENARIOS=30/minute
ASCIIP_RATE_LIMIT_EXPORTS=10/minute
ASCIIP_RATE_LIMIT_STREAM=10/minute

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# When set, emitted as the default X-Correlation-ID on outbound tests/seeds.
ASCIIP_SERVICE_NAME=asciip-api

# Build metadata (populated by CI; safe to leave blank locally)
ASCIIP_VERSION=0.1.0
ASCIIP_BUILD_SHA=
